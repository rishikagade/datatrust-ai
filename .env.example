# DataTrust AI - Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored and should never be committed.

# -- AI Agent (Groq) --------------------------------------------------
# Groq is free to start and does not require a credit card.
# Get your key at: https://console.groq.com
# If not set, the agent uses intelligent rule-based responses.
GROQ_API_KEY=your_groq_key_here

# Model options:
#   llama-3.3-70b-versatile   (best quality, currently verified)
#   llama-3.1-8b-instant      (faster responses)
GROQ_MODEL=llama-3.3-70b-versatile

# -- Backend ----------------------------------------------------------
PORT=8000

# Comma-separated list of allowed frontend origins (no trailing slash)
# Local development:
ALLOWED_ORIGINS=http://localhost:5173
# Production example:
# ALLOWED_ORIGINS=https://datatrust-ai.vercel.app

# -- Frontend ---------------------------------------------------------
# URL of the backend API (no trailing slash)
# Local development:
VITE_BACKEND_URL=http://localhost:8000
# Production example:
# VITE_BACKEND_URL=https://datatrust-ai-backend.onrender.com
